# ============================================================
# AI Spend Audit — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.
# ============================================================

# ----------------------------------------------------------
# App
# ----------------------------------------------------------
# Public URL of the deployed app (used for OG meta tags and email links)
NEXT_PUBLIC_APP_URL=https://credex-spend-audit.vercel.app

# ----------------------------------------------------------
# Supabase — database + lead storage (Feature 7)
# Get these from: https://supabase.com/dashboard/project/<id>/settings/api
# ----------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
# Service role key — server-side only, never expose to client
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ----------------------------------------------------------
# Resend — transactional email (Feature 7)
# Get your API key from: https://resend.com/api-keys
# ----------------------------------------------------------
RESEND_API_KEY=re_your_resend_api_key
# The "from" address for audit confirmation emails (must be a verified domain in Resend)
RESEND_FROM_EMAIL=audit@yourdomain.com

# ----------------------------------------------------------
# Anthropic API — personalized summary generation only (Feature 6)
# Get your API key from: https://console.anthropic.com/settings/keys
# ----------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key

# ----------------------------------------------------------
# Rate limiting (Feature 7 — abuse protection)
# Upstash Redis is used for rate limiting. Get credentials from:
# https://console.upstash.com/
# ----------------------------------------------------------
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token
